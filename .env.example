# Copy to .env and fill in. .env is gitignored.

# AI Studio API key (https://aistudio.google.com/apikey).
# Without it, the agent runs end-to-end using a deterministic offline template for
# the explanation/ranking; set it for live Gemini translation and the recorded demo.
GOOGLE_API_KEY=

# Gemini model id. Default gemini-2.5-flash (gemini-2.0-flash is retired 2026-06-01).
# Use gemini-2.5-pro or gemini-3.5-flash for the recorded demo if quality requires.
GEMINI_MODEL=gemini-2.5-flash

# Port for the local Flask server / Cloud Run (Cloud Run sets this automatically).
PORT=8080
